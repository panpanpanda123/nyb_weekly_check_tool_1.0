# nginx配置 - 多项目管理
# 更新时间: 2026-03-06

server {
    
    # 支持域名和IP访问
    server_name blitzepanda.top 139.224.200.133 _;
    
    # 日志
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;
    
    # 门店评级系统（优先匹配）
    location /rating {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    location /api/rating {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    # 评级系统静态文件（改路径）
    location /static/ {
        alias /var/www/review-result-viewer/viewer/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
    
    # approvalquery 项目
    location /approvalquerynew {
        alias /var/www/approval-viewer/approvalquery;
        index index.html index.htm;
        try_files $uri $uri/ /approvalquerynew/index.html;
        
        # 数据文件缓存控制
        location ~ \.(json|txt|csv|xlsx)$ {
            add_header Cache-Control "no-store, no-cache, must-revalidate";
            add_header Access-Control-Allow-Origin "*";
        }
        
        # 静态资源缓存
        location ~ \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
        }
    }
    
    # 根路径
    location = / {
        return 200 "可用项目:\n- /rating (门店评级)\n- /approvalquery (审批查询)\n";
        add_header Content-Type text/plain;
    }
    
    # 其他路径返回404
    location / {
        return 404;
    }

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/blitzepanda.top/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/blitzepanda.top/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

# 周清审核系统（子域名）- 已填好你的证书路径
server {
    server_name weeklycheck.blitzepanda.top;
    
    # 解决Certbot认证失败的ACME验证路径（必须保留）
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        try_files $uri =404;
    }
    
    # 根路径代理到后端8000端口 - 禁用缓存
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 30s;
        proxy_read_timeout 30s;
        
        # 禁用代理缓存
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        
        # 添加禁用缓存响应头
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
        add_header Pragma "no-cache";
        add_header Last-Modified $date_gmt;
    }
    
    # API路径代理 - 禁用缓存
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 禁用代理缓存
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        
        # 添加禁用缓存响应头
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
        add_header Pragma "no-cache";
    }
    
    # 静态文件路径 - 禁用缓存（解决企微小程序缓存问题）
    location /static/ {
        alias /var/www/nyb_weekly_check_tool_1.0/viewer/static/;
        
        # 完全禁用缓存
        expires -1;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
        add_header Pragma "no-cache";
        
        # 防止代理服务器缓存
        add_header Last-Modified $date_gmt;
        add_header ETag "";
        if_modified_since off;
        
        # CORS支持（如果需要）
        add_header Access-Control-Allow-Origin "*";
    }

    listen 443 ssl;
    # 你的证书路径（已填好，不用改）
    ssl_certificate /etc/nginx/ssl/weeklycheck.blitzepanda.top.pem;
    ssl_certificate_key /etc/nginx/ssl/weeklycheck.blitzepanda.top.key;
    # 复用Certbot的SSL通用配置（和主域名一致，不用改）
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# 子域名80端口重定向（配套保留）
server {
    if ($host = weeklycheck.blitzepanda.top) {
        return 301 https://$host$request_uri;
    }
    
    listen 80;
    server_name weeklycheck.blitzepanda.top;
    # 同样加ACME验证路径
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        try_files $uri =404;
    }
    return 404;
}

